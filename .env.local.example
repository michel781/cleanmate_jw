# Supabase
# Settings → API → **Legacy** tab (NOT the "API keys (new)" tab)
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Site URL (for email redirects, share links)
# In production, set this to your deployed URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# NOTE: SUPABASE_SERVICE_ROLE_KEY is intentionally not listed here.
# It is not used anywhere in the codebase — RLS is the auth layer.
# Add it ONLY if you introduce a server-only feature that needs admin
# access. Service-role key bypasses ALL RLS, so be careful.
